# OpenTelemetry configuration for agent-telemetry.
# Resolution order: process environment > .env file > default value.

# Use stdout exporter instead of OTLP/HTTP when set to "true".
OTEL_STDOUT=false

# OTLP/HTTP endpoint for trace export.
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Optional: override the default service name shown in Jaeger / backends.
# If unset, the library uses "agent-telemetry".
# OTEL_SERVICE_NAME=agent-telemetry
